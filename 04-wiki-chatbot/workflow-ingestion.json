    },
    "Loop Over Items": {
      "main": [
        [],
        [{"index": 0, "node": "Download File", "type": "main"}]
      ]
    },
    "Manual Trigger": {
      "main": [[{"index": 0, "node": "List Wiki Files", "type": "main"}]]
    },
    "OpenAI Embeddings": {
      "ai_embedding": [[{"index": 0, "node": "Supabase Vector Store", "type": "ai_embedding"}]]
    },
    "Supabase Vector Store": {
      "main": [[{"index": 0, "node": "Loop Over Items", "type": "main"}]]
