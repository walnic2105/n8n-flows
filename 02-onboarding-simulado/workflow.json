      }
    }
  ],
  "connections": {
    "FormTrigger": {
      "main": [[{ "node": "LookupDepartmentGroup", "type": "main", "index": 0 }]]
    },
    "LookupDepartmentGroup": {
      "main": [
        [{ "node": "GenerateCredentials", "type": "main", "index": 0 }],
