# =====================================================
# Variables de entorno para n8n-flujos-emblematicos
# Copia este archivo como `.env` y rellena los valores
# reales. NUNCA subas el `.env` al repositorio.
# =====================================================

# --- n8n MCP server ---
# URL base de la API REST de tu instancia n8n.
# IMPORTANTE: la ruta correcta es /api/v1 (no /settings/api,
# que es la página del UI donde se generan las API keys).
N8N_API_URL=https://n8ntest.niorahub.tech/api/v1

# URL base del UI de n8n (sin /api/v1).
N8N_BASE_URL=https://n8ntest.niorahub.tech

# JWT generado en n8n → Settings → API. Pégalo completo.
N8N_API_KEY=pega_aqui_tu_jwt

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Workspace ---
# Service account JSON path para Sheets / Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-sa.json

# ID del Google Sheet donde se escriben los resultados del CV-Scorer
GOOGLE_SHEETS_CV_SCORER_ID=

# OAuth2 client para Google Sheets (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Google Workspace / Cloud Identity (Flujo 02) ---
# Dominio usado para construir los emails corporativos (nombre.apellido@<dominio>).
# En modo demo puede ser cualquier string (no se valida contra Google).
# En producción debe ser un dominio verificado en Cloud Identity/Workspace.
GOOGLE_WORKSPACE_DOMAIN=demo.tudominio.com

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0123456789
# Canales específicos del Flujo 02
SLACK_CHANNEL_ONBOARDING=C0123456789
SLACK_CHANNEL_ERRORS=C0987654321

# --- Airtable ---
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
# Tablas específicas del Flujo 02 (id o nombre)
AIRTABLE_TABLE_DEPARTAMENTOS=Departamentos
AIRTABLE_TABLE_COLABORADORES=Colaboradores
# Tabla específica del Flujo 03 (log diario de ejecuciones del resumidor)
AIRTABLE_TABLE_RUNS=Runs

# --- Flujo 03 — Resumidor Operativo ---
# Canal Slack donde se publica el resumen diario (id que empieza con C...)
SLACK_CHANNEL_RESUMEN=C0123456789

# --- Supabase (RAG Vector Store - Flujo 04) ---
SUPABASE_URL=https://{tu-project-id}.supabase.co
SUPABASE_SERVICE_ROLE_KEY={tu-secret-key-sb_sec_xxx}
# --- OpenAI (Embeddings - Flujo 04) ---
OPENAI_API_KEY={tu-api-key-de-openai}